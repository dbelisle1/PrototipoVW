@model List<PrototipoVW.Models.PropuestaListItemViewModel>

@{
    ViewData["Title"] = "Completar proyecto";
}

<h2>Completar proyecto</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Proyecto</th>
            <th>Área</th>
            <th>Creador</th>
            <th>Presupuesto aprobado</th>
            <th>Fecha creación</th>
            <th style="width: 140px;">Acción</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="6" class="text-center">
                    No hay proyectos aprobados pendientes de completar.
                </td>
            </tr>
        }
        else
        {
            foreach (var propuesta in Model)
            {
                <tr>
                    <td>@propuesta.NombreProyecto</td>
                    <td>@propuesta.AreaSolicitante</td>
                    <td>@propuesta.Creador</td>
                    <td>@propuesta.PresupuestoAprobado.ToString("N2")</td>
                    <td>@propuesta.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <form asp-action="Completar"
                              asp-controller="CompletarProyecto"
                              asp-route-id="@propuesta.IdPropuesta"
                              method="post"
                              onsubmit="return confirm('¿Está seguro de marcar este proyecto como completado?');">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-sm btn-success">
                                Completar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>