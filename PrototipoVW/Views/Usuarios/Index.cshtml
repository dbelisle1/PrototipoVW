@model List<PrototipoVW.Models.UsuarioListItemViewModel>

@{
    ViewData["Title"] = "Usuarios";
}

<h2>Gestión de usuarios</h2>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">
        @TempData["Mensaje"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="mb-3">
    <a asp-action="Create" asp-controller="Usuarios" class="btn btn-primary">
        Agregar
    </a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre completo</th>
            <th>Correo</th>
            <th>Rol</th>
            <th>Fecha creación</th>
            <th style="width: 180px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center">
                    No hay usuarios registrados.
                </td>
            </tr>
        }
        else
        {
            foreach (var usuario in Model)
            {
                <tr>
                    <td>@usuario.NombreCompleto</td>
                    <td>@usuario.Correo</td>
                    <td>@usuario.Rol</td>
                    <td>@usuario.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a asp-action="Edit"
                           asp-controller="Usuarios"
                           asp-route-id="@usuario.IdUsuario"
                           class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <form asp-action="Delete"
                              asp-controller="Usuarios"
                              asp-route-id="@usuario.IdUsuario"
                              method="post"
                              style="display:inline;"
                              onsubmit="return confirm('¿Está seguro de eliminar este usuario?');">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-sm btn-danger">
                                Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>