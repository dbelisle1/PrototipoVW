@model PrototipoVW.Models.UsuarioFormViewModel

@{
    var esEdicion = Model.IdUsuario > 0;
    ViewData["Title"] = esEdicion ? "Editar usuario" : "Agregar usuario";
    var accion = esEdicion ? "Edit" : "Create";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="@accion" asp-controller="Usuarios" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="IdUsuario" />

    <div class="mb-3">
        <label asp-for="NombreCompleto" class="form-label">Nombre completo</label>
        <input asp-for="NombreCompleto" class="form-control" />
        <span asp-validation-for="NombreCompleto" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Correo" class="form-label">Correo</label>
        <input asp-for="Correo" class="form-control" />
        <span asp-validation-for="Correo" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Contrasena" class="form-label">
            Contraseña
        </label>

        <input asp-for="Contrasena" type="password" class="form-control" />

        @if (esEdicion)
        {
            <small class="text-muted">
                Dejar vacío si no desea cambiar la contraseña.
            </small>
        }

        <span asp-validation-for="Contrasena" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Rol" class="form-label">Rol</label>

        <select asp-for="Rol" class="form-select">
            <option value="Admin">Admin</option>
            <option value="Empleado">Empleado</option>
            <option value="Supervisor">Supervisor</option>
        </select>

        <span asp-validation-for="Rol" class="text-danger"></span>
    </div>

    <div class="text-danger mb-3">
        @Html.ValidationSummary()
    </div>

    <button type="submit" class="btn btn-success">
        Guardar
    </button>

    <a asp-action="Index" asp-controller="Usuarios" class="btn btn-secondary">
        Cancelar
    </a>
</form>